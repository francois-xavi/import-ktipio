# Database Configuration
# PostgreSQL connection string from Neon
# Format: postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech:5432/companies?sslmode=require

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Playwright Configuration
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
